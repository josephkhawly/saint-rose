{
  "name": "saint_rose",
  "version": "1.0.0",
  "description": "saint_rose",
  "type": "module",
  "scripts": {
    "dev": "portless saint-rose next dev",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "next start",
    "lint": "eslint .",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "seed": "tsx --env-file=.env src/seed.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "24.0.10",
    "@types/react": "19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@next/third-parties": "16.2.0",
    "@payloadcms/db-vercel-postgres": "^3.81.0",
    "@payloadcms/live-preview-react": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-uploadthing": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@plaiceholder/next": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "classnames": "^2.5.1",
    "formidable": "^2.0.1",
    "graphql": "^16.8.1",
    "lenis": "^1.3.20",
    "motion": "^12.23.12",
    "next": "16.2.0",
    "node-fetch": "2",
    "payload": "^3.81.0",
    "plaiceholder": "^3.0.0",
    "postcss": "^8.5.6",
    "postmark": "^3.0.12",
    "react": "19.2.4",
    "react-awesome-reveal": "^4.3.1",
    "react-dom": "19.2.4",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.12",
    "zod": "^4.0.5"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.14"
    }
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ]
}
