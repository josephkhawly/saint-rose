{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/careers",
            "dest": "/api/careers.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}